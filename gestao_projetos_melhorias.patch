function renderControleDocsGrid(docs, isAdmin) {
  const tbody = document.getElementById('ctrl-docs-tbody');
  if (!tbody) return;
  tbody.innerHTML = '';

  (docs || []).forEach((doc, idx) => {
    const row = document.createElement('tr');
    row.innerHTML = `
      <td><input type="text" class="grid-input" value="${escHtml(doc.codigo || '')}" ${isAdmin ? `onchange="controleDocs[${idx}].codigo=this.value"` : 'readonly'}></td>
      <td><input type="text" class="grid-input" value="${escHtml(doc.atividade || '')}" ${isAdmin ? `onchange="controleDocs[${idx}].atividade=this.value"` : 'readonly'}></td>
      <td><input type="text" class="grid-input" value="${escHtml(doc.doc_numero || '')}" ${isAdmin ? `onchange="controleDocs[${idx}].doc_numero=this.value"` : 'readonly'}></td>
      <td><input type="text" class="grid-input" value="${escHtml(doc.responsavel || '')}" ${isAdmin ? `onchange="controleDocs[${idx}].responsavel=this.value"` : 'readonly'}></td>
      <td><input type="date" class="grid-input" value="${escHtml(doc.data_inicio || '')}" ${isAdmin ? `onchange="controleDocs[${idx}].data_inicio=this.value"` : 'readonly'}></td>
      <td><input type="date" class="grid-input" value="${escHtml(doc.data_conclusao || '')}" ${isAdmin ? `onchange="controleDocs[${idx}].data_conclusao=this.value"` : 'readonly'}></td>
      <td><input type="number" class="grid-input" min="0" max="100" value="${Number(doc.percentual || 0)}" ${isAdmin ? `onchange="controleDocs[${idx}].percentual=parseInt(this.value)||0"` : 'readonly'}></td>
      <td>
        ${isAdmin
          ? `<select class="grid-select" onchange="controleDocs[${idx}].status=this.value">
              <option value="nao_iniciado" ${doc.status === 'nao_iniciado' ? 'selected' : ''}>Não iniciado</option>
              <option value="em_andamento" ${doc.status === 'em_andamento' ? 'selected' : ''}>Em andamento - BK</option>
              <option value="em_analise" ${doc.status === 'em_analise' ? 'selected' : ''}>Em análise - Cliente</option>
              <option value="em_revisao" ${doc.status === 'em_revisao' ? 'selected' : ''}>Em revisão - BK</option>
              <option value="concluido" ${doc.status === 'concluido' ? 'selected' : ''}>Concluído</option>
              <option value="cancelado" ${doc.status === 'cancelado' ? 'selected' : ''}>Cancelado</option>
            </select>`
          : `<div class="grid-input">${escHtml(doc.status || '')}</div>`
        }
      </td>
      <td>
        ${isAdmin
          ? `<textarea class="grid-textarea" onchange="controleDocs[${idx}].observacao=this.value">${escHtml(doc.observacao || '')}</textarea>`
          : `<div class="grid-input">${escHtml(doc.observacao || '')}</div>`
        }
      </td>
      ${isAdmin
        ? `<td class="grid-delete"><button type="button" class="btn btn-danger btn-sm" onclick="excluirDocumentoControle(${idx})">✕</button></td>`
        : ''}
    `;
    tbody.appendChild(row);
  });
}

