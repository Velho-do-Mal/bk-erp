let eapOrgZoom = 1;

function zoomEapOrg(step) {
  eapOrgZoom = Math.max(0.4, Math.min(2.4, Number((eapOrgZoom + step).toFixed(2))));
  const tree = document.getElementById('eap-org-tree');
  if (tree) tree.style.transform = `scale(${eapOrgZoom})`;
}

function resetEapOrgZoom() {
  eapOrgZoom = 1;
  const tree = document.getElementById('eap-org-tree');
  if (tree) tree.style.transform = 'scale(1)';
}

