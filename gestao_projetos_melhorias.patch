*** Replace Function: renderEAP
function renderEAP() {
  const tbody = el('eap-tbody');
  if (!tbody) return;

  tbody.innerHTML = '';

  const codes = eapTasks.map(t => String(t.codigo || '').trim());
  const isSummary = {};
  codes.forEach(c => {
    const parts = c.split('.');
    for (let i = 1; i < parts.length; i++) {
      const parent = parts.slice(0, i).join('.');
      isSummary[parent] = true;
    }
  });

  const _dateTasks = calcularDatas();
  const _dateMap = {};
  _dateTasks.forEach(dt => { _dateMap[dt.codigo] = dt; });

  eapTasks.forEach((t, idx) => {
    const cod = String(t.codigo || '').trim();
    const depth = cod.split('.').length - 1;
    const summary = isSummary[cod] || false;
    const pct = parseFloat(t.percentualConcluido || t.pct || 0);
    const status = t.status || 'nao-iniciado';
    const indent = 12 + depth * 20;

    const _de = _dateMap[t.codigo] || {};
    const _dtIniISO = t.dtInicioManual || (_de.startDate ? _de.startDate.toISOString().split('T')[0] : '');
    const _dtFimISO = t.dtConclusaoManual || (_de.endDate ? _de.endDate.toISOString().split('T')[0] : '');

    const statusRead = {
      'concluido': 'Concluído',
      'em-andamento': 'Em Andamento',
      'atrasado': 'Atrasado',
      'nao-iniciado': 'Não Iniciado'
    }[status] || status;

    const tr = document.createElement('tr');
    tr.className = ((summary ? 'eap-row-summary' : 'eap-row-normal') + ' eap-level-' + depth);

    tr.innerHTML = `
      <td><input type="text" class="grid-input" value="${escHtml(cod)}" ${IS_ADMIN ? `onchange="eapTasks[${idx}].codigo=this.value"` : 'readonly'}></td>
      <td>
        ${IS_ADMIN
          ? `<input type="text" class="grid-input" style="padding-left:${indent}px;${summary ? 'font-weight:700;' : ''}" value="${escHtml(t.nome || '')}" onchange="eapTasks[${idx}].nome=this.value">`
          : `<div class="grid-input" style="padding-left:${indent}px;${summary ? 'font-weight:700;' : ''}">${escHtml(t.nome || '')}</div>`
        }
      </td>
      <td>${IS_ADMIN
          ? `<input type="number" class="grid-input" value="${t.duracao || 0}" onchange="eapTasks[${idx}].duracao=parseInt(this.value)||0">`
          : `<div class="grid-input">${t.duracao || 0}</div>`}
      </td>
      <td><input type="text" class="grid-input" value="${escHtml(String(t.predecessoras || ''))}" ${IS_ADMIN ? `onchange="eapTasks[${idx}].predecessoras=this.value"` : 'readonly'}></td>
      <td>${IS_ADMIN
          ? `<input type="date" class="grid-input" value="${_dtIniISO}" onchange="setTkDate(${idx},'i',this.value)">`
          : `<div class="grid-input">${_dtIniISO ? new Date(_dtIniISO + 'T12:00').toLocaleDateString('pt-BR') : '—'}</div>`}
      </td>
      <td>${IS_ADMIN
          ? `<input type="date" class="grid-input" value="${_dtFimISO}" onchange="setTkDate(${idx},'f',this.value)">`
          : `<div class="grid-input">${_dtFimISO ? new Date(_dtFimISO + 'T12:00').toLocaleDateString('pt-BR') : '—'}</div>`}
      </td>
      <td>${IS_ADMIN
          ? `<input type="number" class="grid-input" value="${pct}" min="0" max="100" onchange="eapTasks[${idx}].percentualConcluido=parseFloat(this.value)||0">`
          : `<div class="grid-input">${pct}%</div>`}
      </td>
      <td>${IS_ADMIN
          ? `<select class="grid-select" onchange="eapTasks[${idx}].status=this.value">
              <option value="nao-iniciado" ${status === 'nao-iniciado' ? 'selected' : ''}>Não Iniciado</option>
              <option value="em-andamento" ${status === 'em-andamento' ? 'selected' : ''}>Em Andamento</option>
              <option value="concluido" ${status === 'concluido' ? 'selected' : ''}>Concluído</option>
              <option value="atrasado" ${status === 'atrasado' ? 'selected' : ''}>Atrasado</option>
            </select>`
          : `<div class="grid-input">${statusRead}</div>`}
      </td>
      <td><input type="text" class="grid-input" value="${escHtml(t.responsavel || '')}" ${IS_ADMIN ? `onchange="eapTasks[${idx}].responsavel=this.value"` : 'readonly'}></td>
      ${IS_ADMIN
        ? `<td class="grid-delete"><button type="button" class="btn btn-danger btn-sm" onclick="removerTarefa(${idx})">✕</button></td>`
        : ''}
    `;
    tbody.appendChild(tr);
  });
}

