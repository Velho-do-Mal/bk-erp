function excluirDocumentoControle(idx) {
  if (!Array.isArray(controleDocs)) return;
  if (!confirm('Excluir esta linha?')) return;
  controleDocs.splice(idx, 1);
  renderControleDocsGrid(controleDocs, IS_ADMIN);
}
